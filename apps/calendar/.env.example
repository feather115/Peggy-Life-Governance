VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# LINE LIFF（讓 App 可以用 https://liff.line.me/<LIFF_ID> 連結在 LINE 內開啟，不跳出外部瀏覽器）
# 在 LINE Developers Console 建立 LIFF app 後取得，沒設定就跳過、當一般網頁用
VITE_LIFF_ID=YOUR_LIFF_ID

# LINE 自動登入用，伺服器端才需要，不能加 VITE_ 前綴
# LINE_CHANNEL_ID：LINE Login channel 的 Basic settings 頁面，「Channel ID」那個數字（公開、非密鑰）
# SUPABASE_SERVICE_ROLE_KEY：Supabase 專案 Settings → API → service_role key（極機密，會繞過所有 RLS，絕對不能外流）
LINE_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
